# Polymarket API Credentials
# Get these from https://polymarket.com/settings (API Keys section)

POLYGON_PRIVATE_KEY=your_private_key_here
CLOB_API_KEY=your_api_key_here
CLOB_SECRET=your_api_secret_here
CLOB_PASSPHRASE=your_api_passphrase_here

# Bot Settings
TRADE_LIMIT_USD=10.0
SLIPPAGE_TOLERANCE=0.01
LIVE_MODE=false
MIN_PROFIT_USD=0.01

# Performance Constraints
# Max suggested markets: ~250 (higher may cause slow scan loops and rate limits)
MARKET_SCAN_LIMIT=100
# Min time between polls: ~2 to 4 seconds (going too fast might hit rate limits)
POLL_INTERVAL_SECONDS=3

# Kalshi API (US Regulated - v2 API Keys)
# Generate these at https://kalshi.com/settings/api
KALSHI_API_KEY_ID=your_key_id_uuid
KALSHI_PRIVATE_KEY_PATH=/path/to/your/kalshi_private_key.pem
KALSHI_ENVIRONMENT=demo # 'demo' or 'prod'
